# Local dev: use Vite proxy (see vite.config.ts) — paths are relative
VITE_API_BASE_URL=/api/v1
VITE_BASE_UPLOAD_URL=/uploads
VITE_COMPANY_API_BASE_URL=/api/v1
VITE_FORGET_PASS=/api/v1/forgot-password
VITE_RESET_PASS=/api/v1/reset-password

# Production example:
# VITE_API_BASE_URL=https://api.haqtravels.co.uk/api/v1
# VITE_BASE_UPLOAD_URL=https://api.haqtravels.co.uk/uploads
# VITE_COMPANY_API_BASE_URL=https://api.haqtravels.co.uk/api/v1
